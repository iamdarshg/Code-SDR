(version 1)

# Starter rules for the V2 redraw. Widths are based on the present nominal
# stackup only and must be recalculated against the fabricator's impedance model.

(rule "RF grounded coplanar outer layers"
    (layer outer)
    (constraint track_width (min 0.36mm) (opt 0.38mm) (max 0.40mm))
    (constraint clearance (min 0.18mm))
    (constraint via_count (max 0))
    (condition "A.NetClass == 'RF_50R_HIGH'")
)

(rule "RF 50 ohm outer layers"
    (layer outer)
    (constraint track_width (min 0.34mm) (opt 0.38mm) (max 0.42mm))
    (constraint clearance (min 0.18mm))
    (condition "A.NetClass == 'RF_50R'")
)

(rule "No high-band RF on inner layers"
    (layer inner)
    (constraint disallow track via)
    (condition "A.NetClass == 'RF_50R_HIGH'")
)

(rule "No high-band RF on back layer"
    (layer "B.Cu")
    (constraint disallow track via)
    (condition "A.NetClass == 'RF_50R_HIGH'")
)

(rule "100 ohm differential pairs"
    (layer outer)
    (constraint track_width (min 0.16mm) (opt 0.18mm) (max 0.20mm))
    (constraint diff_pair_gap (min 0.16mm) (opt 0.18mm) (max 0.20mm))
    (constraint diff_pair_uncoupled (max 2mm))
    (condition "A.NetClass == 'DIFF_100R'")
)

(rule "USB 90 ohm differential"
    (layer outer)
    (constraint track_width (min 0.16mm) (opt 0.18mm) (max 0.20mm))
    (constraint diff_pair_gap (min 0.14mm) (opt 0.16mm) (max 0.18mm))
    (constraint diff_pair_uncoupled (max 1mm))
    (condition "A.NetClass == 'USB_90R'")
)

(rule "ADC clock"
    (layer outer)
    (constraint track_width (min 0.34mm) (opt 0.38mm) (max 0.42mm))
    (constraint clearance (min 0.20mm))
    (constraint length (max 35mm))
    (condition "A.NetClass == 'ADC_CLK'")
)

(rule "Power routing"
    (constraint track_width (min 0.50mm))
    (constraint via_diameter (min 0.60mm))
    (constraint hole_size (min 0.30mm))
    (condition "A.NetClass == 'POWER'")
)
